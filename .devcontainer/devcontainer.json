{
  "name": "SystemC Tutorial",
  "image": "mcr.microsoft.com/devcontainers/cpp:1-ubuntu-24.04",
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cpptools",
        "ms-vscode.cmake-tools"
      ]
    }
  },
  "remoteEnv": {
    "SYSTEMC_HOME": "/usr/local/systemc-2.3.3",
    "LD_LIBRARY_PATH": "/usr/local/systemc-2.3.3/lib-linux64:${LD_LIBRARY_PATH}"
  },
  "onCreateCommand": "bash .devcontainer/install-systemc.sh"
}
